EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Android Google Maps SDK key — react-native-maps shows a BLANK map on Android
# without it. Create one in Google Cloud (enable "Maps SDK for Android"), then
# expose it to EAS builds as a secret:  eas secret:create --name GOOGLE_MAPS_API_KEY --value <key>
GOOGLE_MAPS_API_KEY=your-android-google-maps-key
